<IfModule mod_rewrite.c>
    # Bật tính năng viết lại đường dẫn của Apache
    RewriteEngine On

    # Nếu người dùng truy cập thẳng vào một file hoặc thư mục CÓ THẬT (ví dụ ảnh, css, js) thì giữ nguyên, không điều hướng.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # ==========================================
    # 1. ĐIỀU HƯỚNG CÁC ENDPOINT API
    # ==========================================
    # Chuyển nanolink.local/api/shorten -> nanolink.local/api/shorten.php
    # Chuyển nanolink.local/api/stats -> nanolink.local/api/stats.php
    RewriteRule ^api/([a-zA-Z0-9_-]+)$ api/$1.php [L,QSA]

    # ==========================================
    # 2. ĐIỀU HƯỚNG MÃ RÚT GỌN (SHORT LINK & CUSTOM ALIAS)
    # ==========================================
    # Bắt các chuỗi nằm ngay sau tên miền (chứa chữ hoa, chữ thường, số, dấu gạch ngang, gạch dưới)
    # Chuyển nanolink.local/My-App -> nanolink.local/api/redirect.php?code=My-App
    RewriteRule ^([a-zA-Z0-9_-]+)$ api/redirect.php?code=$1 [L,QSA]

</IfModule>